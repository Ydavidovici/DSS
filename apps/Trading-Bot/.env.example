APCA_API_KEY=your_alpaca_api_key_here
APCA_SECRET_KEY=your_alpaca_secret_key_here
APCA_PAPER=true
APCA_API_BASE_URL=https://paper-api.alpaca.markets
DB_SERVICE_URL=http://localhost:4000/api
FAST_MA_PERIOD=10
SLOW_MA_PERIOD=50
TIMEFRAME=1d
SYMBOLS=AAPL,SPY
USE_EMA=false
MIN_SIGNAL_STRENGTH=0.5
POSITION_SIZE_PERCENT=10
MAX_POSITIONS=5
ACCOUNT_ID=default
DRY_RUN=true
EXECUTION_SCHEDULE=0 16 * * 1-5
RUN_ONCE=false
ENABLE_SCHEDULE=true
LOG_LEVEL=info