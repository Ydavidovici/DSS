# Alpaca API Configuration
APCA_API_KEY=your_alpaca_api_key_here
APCA_SECRET_KEY=your_alpaca_secret_key_here
APCA_PAPER=true
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# Database Service Configuration
DB_SERVICE_URL=http://localhost:3000/api

# Strategy Configuration
FAST_MA_PERIOD=10
SLOW_MA_PERIOD=50
TIMEFRAME=1d
SYMBOLS=AAPL,SPY

# Trading Configuration
POSITION_SIZE_PERCENT=10
MAX_POSITIONS=5
ACCOUNT_ID=default

# Execution Schedule (cron format)
# Example: "0 16 * * 1-5" = 4 PM weekdays (after market close)
EXECUTION_SCHEDULE=0 16 * * 1-5

# Logging
LOG_LEVEL=info
