{
    "name": "db-service",
    "version": "0.2.1",
    "main": "src/index.ts",
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "start": "NODE_ENV=production bun src/index.ts",
        "typecheck": "tsc --noEmit",
        "build": "bun build src/index.ts --outdir ./dist --target bun --packages external",
        "knex": "bunx --bun knex",
        "migrate:make": "bunx --bun knex migrate:make",
        "migrate:latest": "bunx --bun knex migrate:latest",
        "migrate:rollback": "bunx --bun knex migrate:rollback",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:coverage": "bun test --coverage"
    },
    "dependencies": {
        "@types/express": "^5.0.6",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.1",
        "helmet": "^8.1.0",
        "jose": "^6.0.12",
        "knex": "^2.4.0",
        "pg": "^8.11.0",
        "pino": "^8.14.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bun": "^1.1.14",
        "@types/cors": "^2.8.19",
        "@types/supertest": "^2.0.12",
        "supertest": "^6.3.3",
        "typescript": "^5.1.3"
    }
}